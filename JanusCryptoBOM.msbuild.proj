<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <RootDir>$(MSBuildThisFileDirectory)</RootDir>
  </PropertyGroup>

  <Target Name="Build">
    <Exec Command="powershell -ExecutionPolicy Bypass -File &quot;$(RootDir)build-windows.ps1&quot;" />
  </Target>

  <Target Name="BuildNoTools">
    <Exec Command="powershell -ExecutionPolicy Bypass -File &quot;$(RootDir)build-windows.ps1&quot; -SkipToolInstall" />
  </Target>
</Project>
